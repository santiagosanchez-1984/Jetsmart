# Google Cloud — Service Account dedicado a JetSMART (lectura/escritura de la planilla)
GOOGLE_CLIENT_EMAIL=jetsmart-si@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY_ID=...
# Private key completa en base64 (evita problemas de saltos de linea en .env)
# Generarla con: node -e "console.log(Buffer.from(require('./key.json').private_key).toString('base64'))"
GOOGLE_PRIVATE_KEY=...

# ID de la planilla de Google Sheets de JetSMART
SHEET_ID=1RRVvrNopcHm-HpKDbUrRE3yMGHNYArNtQNJuvG_-rmE

# Smiles — credenciales de la API (hoy hardcodeadas en jetsmart.gs / smiles-proxy.js)
SMILES_API_KEY=...
SMILES_MEMBER=...

# Gmail — OAuth para "Importar desde Gmail" (generado una vez con scripts/gmail-oauth-setup.js)
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...

# Login (pantalla propia, sesion via cookie firmada) para toda la app
AUTH_USER=...
AUTH_PASS=...
# Secreto para firmar la cookie de sesion (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET=...
